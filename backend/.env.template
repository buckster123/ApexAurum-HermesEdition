# ApexAurum Hermes Edition — Local Configuration Template
# Copy to .env and fill in your keys. Uncomment what you need.

# ═══════════════════════════════════════════════════════════════════════════
# CORE (auto-detected — usually no need to change)
# ═══════════════════════════════════════════════════════════════════════════

# Already defaults to True for Hermes Edition. Set to false only for cloud deploys.
# LOCAL_MODE=true

# Database (Docker container or local PostgreSQL)
DATABASE_URL=postgresql://apex:apex@localhost:5432/apex

# Secret key for encryption — change this in production
SECRET_KEY=change-me-in-production-apexaurum-local

# ═══════════════════════════════════════════════════════════════════════════
# LLM PROVIDER API KEYS — add the ones you use
# ═══════════════════════════════════════════════════════════════════════════

# Anthropic (Claude Sonnet/Opus) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter (universal gateway — Anthropic, Google, Meta, DeepSeek, etc.)
# https://openrouter.ai/keys  — ONE key unlocks 200+ models
OPENROUTER_API_KEY=

# Moonshot / Kimi — https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# Local providers need no keys (Ollama, LM Studio, vLLM run on your machine)

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════

# Suno AI music generation — https://sunoapi.org
SUNO_API_KEY=

# Stripe (only needed for cloud billing; local mode ignores this)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Email (SMTP) — for password reset etc. (optional in local mode)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Initial admin (auto-created on first startup)
# INITIAL_ADMIN_EMAIL=admin@apexaurum.local
# INITIAL_ADMIN_PASSWORD=
