# ApexAurum Local - Environment Configuration

# ===========================================
# REQUIRED
# ===========================================

# Anthropic API Key (required for chat)
ANTHROPIC_API_KEY=sk-ant-...

# Database URL
DATABASE_URL=postgresql+asyncpg://apex:apex_dev_password@localhost:5432/apex

# Secret key for JWT (generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-in-production

# ===========================================
# LOCAL MODE
# ===========================================

# Enable local single-user mode (no login required)
LOCAL_MODE=true

# Default user credentials (auto-created on startup)
LOCAL_DEFAULT_USER_EMAIL=local@apexaurum.local
LOCAL_DEFAULT_USER_PASSWORD=apex

# ===========================================
# OPTIONAL PROVIDERS
# ===========================================

# OpenAI-compatible local endpoints (Ollama, LM Studio, vLLM)
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Together AI
# TOGETHER_API_KEY=

# Groq
# GROQ_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# Qwen
# DASHSCOPE_API_KEY=

# Moonshot
# MOONSHOT_API_KEY=

# Voyage AI for better embeddings
# VOYAGE_API_KEY=

# Suno AI for music generation
# SUNO_API_KEY=

# ===========================================
# DEFAULTS
# ===========================================

# Debug mode (enables API docs, verbose logging)
DEBUG=true

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# File vault path
VAULT_PATH=./data
